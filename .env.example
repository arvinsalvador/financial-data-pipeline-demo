# Copy this file to .env for local development. Change passwords outside local demos.
APP_NAME=CFO Financial Data Pipeline Demo
ENVIRONMENT=development

POSTGRES_DB=financial_pipeline
POSTGRES_USER=pipeline
POSTGRES_PASSWORD=pipeline_dev_password
POSTGRES_PORT=5432

BACKEND_PORT=8000
FRONTEND_PORT=5173
CORS_ORIGINS=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Phase 2A source-file intake
ALLOWED_SOURCE_FILE_EXTENSIONS=.csv
ALLOWED_SOURCE_FILE_MIME_TYPES=text/csv,application/csv,application/vnd.ms-excel,text/plain,application/octet-stream
MAX_UPLOAD_SIZE_BYTES=262144000
VALIDATION_VERSION=1.0.0
DEFAULT_VALIDATION_RULE_SET=financial_data_quality_v1
VALIDATION_REPORT_ROOT=/data/generated/reports/validation
VALIDATION_MAX_ISSUES_PER_RULE=5000
RECONCILIATION_VERSION=1.0.0
RECONCILIATION_AMOUNT_TOLERANCE=0.01
RECONCILIATION_DATE_TOLERANCE_DAYS=3
RECONCILIATION_MIN_AUTO_ACCEPT_CONFIDENCE=0.98
RECONCILIATION_MIN_SUGGESTION_CONFIDENCE=0.65
RECONCILIATION_MAX_GROUP_SIZE=5
RECONCILIATION_MAX_CANDIDATES_PER_RECORD=20
RECONCILIATION_DESCRIPTION_SIMILARITY_THRESHOLD=0.35
RECONCILIATION_REFERENCE_SIMILARITY_THRESHOLD=0.8
RECONCILIATION_PARTIAL_MATCH_MINIMUM_AMOUNT=1.0
RECONCILIATION_REVERSAL_DATE_TOLERANCE_DAYS=7
RECONCILIATION_DUPLICATE_DATE_TOLERANCE_DAYS=0
RECONCILIATION_AUTO_ACCEPT_GROUPED_MATCHES=false
RECONCILIATION_REPORT_ROOT=/data/reports/reconciliation/bank-ledger
PAYROLL_RECONCILIATION_VERSION=1.0.0
PAYROLL_RECONCILIATION_AMOUNT_TOLERANCE=0.01
PAYROLL_RECONCILIATION_DATE_TOLERANCE_DAYS=3
PAYROLL_RECONCILIATION_DEFAULT_SETTLEMENT_MODEL=net_pay_only
PAYROLL_RECONCILIATION_MIN_AUTO_ACCEPT_CONFIDENCE=0.98
PAYROLL_RECONCILIATION_MIN_SUGGESTION_CONFIDENCE=0.65
PAYROLL_RECONCILIATION_MAX_BANK_GROUP_SIZE=5
PAYROLL_RECONCILIATION_MAX_GL_GROUP_SIZE=20
PAYROLL_RECONCILIATION_MAX_CANDIDATES_PER_RUN=20
PAYROLL_RECONCILIATION_DUPLICATE_DATE_TOLERANCE_DAYS=0
PAYROLL_RECONCILIATION_REVERSAL_DATE_TOLERANCE_DAYS=7
PAYROLL_RECONCILIATION_EMPLOYEE_TOLERANCE=0.01
PAYROLL_RECONCILIATION_REPORT_ROOT=/data/reports/reconciliation/payroll
INVOICE_COLLECTIONS_RECONCILIATION_VERSION=1.0.0
INVOICE_COLLECTIONS_AMOUNT_TOLERANCE=0.01
INVOICE_COLLECTIONS_DATE_TOLERANCE_DAYS=3
INVOICE_COLLECTIONS_MIN_AUTO_ACCEPT_CONFIDENCE=0.98
INVOICE_COLLECTIONS_MIN_SUGGESTION_CONFIDENCE=0.65
INVOICE_COLLECTIONS_MAX_PAYMENTS_PER_INVOICE=10
INVOICE_COLLECTIONS_MAX_INVOICES_PER_PAYMENT=10
INVOICE_COLLECTIONS_MAX_PAYMENTS_PER_DEPOSIT=10
INVOICE_COLLECTIONS_MAX_DEPOSITS_PER_PAYMENT=5
INVOICE_COLLECTIONS_MAX_CANDIDATES_PER_RECORD=20
INVOICE_COLLECTIONS_AUTO_ACCEPT_GROUPED=false
INVOICE_COLLECTIONS_OVERPAYMENT_TOLERANCE=0.01
INVOICE_COLLECTIONS_OVERDUE_WARNING_DAYS=30
INVOICE_COLLECTIONS_AGING_BUCKETS=current,1_30,31_60,61_90,over_90
INVOICE_COLLECTIONS_REPORT_ROOT=/data/reports/reconciliation/invoice-collections
GENERATOR_VERSION=1.0.0
GENERATION_RANDOM_SEED=20260714
GENERATED_DATA_DIRECTORY=/data/generated
GENERATED_CUSTOMER_COUNT=8
GENERATION_MIN_CUSTOMER_DEPOSIT=0.01
MESSY_GENERATOR_VERSION=1.0.0
DEFAULT_DEFECT_SCENARIO=standard_messy_v1
MESSY_GENERATION_RANDOM_SEED=20260714
MAX_DEFECTS_PER_RUN=500
MAX_MUTATION_VALUE_LENGTH=500
MESSY_GENERATED_ROOT=/data/generated/messy
MESSY_MANIFEST_ROOT=/data/generated/manifests/messy
MESSY_REPORT_ROOT=/data/generated/reports/messy
MESSY_DETERMINISM_VERIFICATION_ENABLED=true
SCENARIO_RULE_CONFLICT_POLICY=skip_later

# Phase 2B CSV profiling
PROFILING_VERSION=1.0.0
CSV_READ_CHUNK_SIZE=1000
MAX_SAMPLED_VALUES_PER_COLUMN=5
NULL_PERCENTAGE_WARNING_THRESHOLD=50
RUNNING_BALANCE_TOLERANCE=0.01
SUPPORTED_ENCODINGS=utf-8-sig,utf-8
MAX_PROFILING_ROW_COUNT=100000

# Phase 3 development-only governance context. Must be false in production.
ENABLE_DEMO_ACTOR_HEADERS=true
DEFAULT_DEMO_TENANT_CODE=demo_coffee_group
DEFAULT_DEMO_USER_EMAIL=analyst@demo.local
