# Copy this file to .env for local development. Change passwords outside local demos.
APP_NAME=CFO Financial Data Pipeline Demo
ENVIRONMENT=development

POSTGRES_DB=financial_pipeline
POSTGRES_USER=pipeline
POSTGRES_PASSWORD=pipeline_dev_password
POSTGRES_PORT=5432

BACKEND_PORT=8000
FRONTEND_PORT=5173
CORS_ORIGINS=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Phase 2A source-file intake
ALLOWED_SOURCE_FILE_EXTENSIONS=.csv
ALLOWED_SOURCE_FILE_MIME_TYPES=text/csv,application/csv,application/vnd.ms-excel,text/plain,application/octet-stream
MAX_UPLOAD_SIZE_BYTES=10485760
